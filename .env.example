PORT=3001
PUBLIC_BASE_URL=https://zhidu.xh028.com

# 企业微信网页 OAuth 登录
WECOM_CORP_ID=your_corpid
WECOM_AGENT_ID=your_agentid
WECOM_CORP_SECRET=your_app_secret

# 企业微信「接收消息服务器配置」
WECOM_TOKEN=your_message_token
WECOM_ENCODING_AES_KEY=your_43_char_encoding_aes_key

# 可选：逗号分隔。配置后这些企业微信 UserId 拥有后台权限。
WECOM_ADMIN_USERIDS=
